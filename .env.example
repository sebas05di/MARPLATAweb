# =============================================================
# MARPLATA — Variables de entorno (EJEMPLO)
# Copiá este archivo como `.env` (dev) o `.env.prod` (prod)
# y completá los valores reales.
# =============================================================

# ---- Django core ----
SECRET_KEY=tu-clave-secreta-larga-y-aleatoria
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
SITE_URL=http://localhost:8000

# ---- Database (PostgreSQL) ----
# Formato: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:2005@localhost:5433/marplata_db

# ---- WhatsApp Business ----
# Número con código de país, sin espacios ni signos
MARPLATA_WHATSAPP_NUMBER=+573001234567

# ---- Email (elegir UN backend) ----
# Opción A: SendGrid API (recomendado para PaaS como Render/Railway)
SENDGRID_API_KEY=

# Opción B: SMTP tradicional (funciona bien en VPS)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=MARPLATA <no-reply@marplata.com>

# ---- Cloudinary (recomendado para producción) ----
# Si no se configura, los media files se guardan localmente en /media/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ---- Sentry (opcional — monitoreo de errores) ----
SENTRY_DSN=

# ---- Admin alerts ----
ADMIN_EMAIL=admin@marplata.com

# ---- Hosting específico (Render setea esto automáticamente) ----
RENDER_EXTERNAL_HOSTNAME=
